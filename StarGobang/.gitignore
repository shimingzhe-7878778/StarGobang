# ==============================================================================
# StarGobang Project - Global .gitignore
# ==============================================================================

# Python Virtual Environments (Python 虚拟环境)
# Location: python/.venv/, root/.venv/
.venv/
venv/
env/
.env/
conda-env/
env_backup/

# Python Cache and Build Files (Python 缓存和编译产物)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# C++ Build Directories (C++ 编译产物)
# Location: cpp/build/, cpp/cmake-build-*/
cpp/build/
cpp/cmake-build-debug/
cpp/cmake-build-release/
cpp/.cmake/
cpp/Testing/
*.exe
*.dll
*.obj
*.lib
*.a
*.out
*.bin
*.dylib

# IDE Configuration Files (IDE 配置文件)
# PyCharm, CLion, VSCode, etc.
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs and Temporary Files (日志和临时文件)
# Location: python/logs/
python/logs/
logs/
*.log
*.tmp
*.temp
.cache/

# Model Checkpoints and Training Data (模型检查点和训练数据)
# Location: python/checkpoints/, python/models/
python/checkpoints/*.pth
python/checkpoints/*.onnx
python/models/*.pth
python/models/*.onnx
checkpoints/
models/

# Large Binary Files (大文件和压缩包)
*.zip
*.rar
*.7z
*.tar.gz
*.gz
*.bz2

# ONNX Runtime Libraries (ONNX Runtime 库，体积较大)
onnxruntime/

# Test Files (测试文件)
.tox/
.nox/
coverage.xml
.coverage.*

# Backup Files (备份文件)
*.bak
*.backup
*~